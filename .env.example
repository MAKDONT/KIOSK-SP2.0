# ============================================================================
# ENVIRONMENT VARIABLES - COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# ============================================================================
# NEVER commit actual credentials to version control!
# Keep .env.local in .gitignore

# NODE_ENV: Application environment (development, production, staging)
NODE_ENV="production"

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Supabase anonymous key for client-side access
SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# SUPABASE_SERVICE_ROLE_KEY: The service role key for backend access (KEEP PRIVATE)
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# SUPABASE_RECORDINGS_BUCKET: Private Storage bucket for consultation audio.
SUPABASE_RECORDINGS_BUCKET="consultation-recordings"

# SUPABASE_RECORDINGS_PREFIX: Folder prefix inside the bucket.
SUPABASE_RECORDINGS_PREFIX="recordings"

# SUPABASE_RECORDINGS_RETENTION_HOURS: Auto-delete recordings older than this many hours.
SUPABASE_RECORDINGS_RETENTION_HOURS="48"

# ============================================================================
# SENDGRID EMAIL CONFIGURATION
# ============================================================================

# SENDGRID_API_KEY: SendGrid API key for email notifications (KEEP PRIVATE)
SENDGRID_API_KEY="your_sendgrid_api_key_here"

# SENDGRID_FROM_EMAIL: Verified sender address in SendGrid
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"

# ============================================================================
# GOOGLE OAUTH & WORKSPACE CONFIGURATION
# ============================================================================

# GOOGLE_CLIENT_ID: Your Google Cloud OAuth Client ID
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"

# GOOGLE_CLIENT_SECRET: Your Google Cloud OAuth Client Secret (KEEP PRIVATE)
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# GOOGLE_REDIRECT_URI: OAuth callback URL (must match Google Cloud Console)
# Example: https://your-app.onrender.com/api/auth/google/callback
GOOGLE_REDIRECT_URI="https://your-app.onrender.com/api/auth/google/callback"

# GOOGLE_REDIRECT_URL: Alternative form of GOOGLE_REDIRECT_URI
GOOGLE_REDIRECT_URL="https://your-app.onrender.com/api/auth/google/callback"

# ============================================================================
# GMAIL CONFIGURATION
# ============================================================================

# GMAIL_USER: Gmail account for sending notifications
GMAIL_USER="your-email@gmail.com"

# GMAIL_APP_PASSWORD: Gmail app-specific password (NOT your regular password)
# Generate from: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD="your_gmail_app_password_here"

# ============================================================================
# GOOGLE DRIVE INTEGRATION
# ============================================================================

# GOOGLE_DRIVE_FOLDER_ID: Google Drive folder ID for storing uploads
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id_here"

# ============================================================================
# GEMINI AI CONFIGURATION
# ============================================================================

# GEMINI_API_KEY: Gemini AI API key for AI-powered features (KEEP PRIVATE)
GEMINI_API_KEY="your_gemini_api_key_here"

# ============================================================================
# GOOGLE WORKSPACE SERVICE ACCOUNT (Optional)
# ============================================================================

# GOOGLE_MEET_DELEGATED_USER: Workspace user email for domain-wide delegation
# Used for server-side Google Meet auto-link generation
GOOGLE_MEET_DELEGATED_USER="your-workspace-user@yourdomain.com"

# GOOGLE_SERVICE_ACCOUNT_JSON: Service account key JSON (for server-side auth)
# Can be provided as single-line JSON or base64-encoded
GOOGLE_SERVICE_ACCOUNT_JSON="your_service_account_json_here_or_base64"

# ============================================================================
# APPLICATION URLS
# ============================================================================

# ALLOWED_ORIGINS: Comma-separated list of allowed frontend origins (CORS)
# Example: https://kiosk-sp2-0.onrender.com/,https://localhost:3000
ALLOWED_ORIGINS="https://your-domain.onrender.com/"

# APP_BASE_URL: Public base URL for your application
# Used for constructing callback URLs and creating shareable links
APP_BASE_URL="https://your-domain.onrender.com/"

# ============================================================================
# APPLICATION DATA
# ============================================================================

# APP_DATA_DIR: Directory for persisted runtime files (uploads, tokens)
# Example on Render: /var/data
APP_DATA_DIR="/var/data"
